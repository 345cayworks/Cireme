# CIREME environment configuration
# Copy to .env.local for development. Never commit real secrets.

# Netlify DB (Neon serverless Postgres) connection string
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Auth.js session secret. Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-strong-random-secret"

# Base URL of the deployment (used by Auth.js callbacks)
AUTH_URL="http://localhost:3000"
