# CIREME environment configuration
# Copy to .env.local for development. Never commit real secrets.

# Netlify DB (Neon serverless Postgres) connection string
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Auth.js session secret. Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-strong-random-secret"

# Base URL of the deployment (used by Auth.js callbacks)
AUTH_URL="http://localhost:3000"

# Super-admin bootstrap (used only by `npm run db:bootstrap-admin`).
# SUPERADMIN_MASTER_KEY becomes the super-admin password (bcrypt-hashed);
# use a strong value (>= 16 chars) and rotate by re-running the script.
SUPER_ADMIN_EMAIL="superadmin@example.ky"
SUPERADMIN_MASTER_KEY="replace-with-a-strong-master-key-min-16-chars"
